# ╔════════════════════════════════════════════════════════════════════════╗
# ║  TruthSeeker 环境变量配置示例                                          ║
# ║  复制为 .env 并填入实际值：cp .env.example .env                        ║
# ╚════════════════════════════════════════════════════════════════════════╝


# ── 1️⃣ 必填 (缺失会阻止启动) ──────────────────────────────────────────────

# JWT 签名密钥 — 用于签发/验证登录 Token & 派生 AES 加密密钥
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# PostgreSQL 密码 — 生产和开发数据库访问凭据
# 与 docker-compose.yml 中 POSTGRES_PASSWORD 对应
POSTGRES_PASSWORD=

# Logto 配置 (后端 OIDC 交换与 Resource Server 校验)
LOGTO_ENDPOINT=https://your-logto-endpoint.logto.app/
LOGTO_CLIENT_ID=your-client-id
LOGTO_CLIENT_SECRET=your-client-secret
LOGTO_API_RESOURCE=https://api.truthseeker.com


# ── 2️⃣ 可选 (有默认值，不设置也能跑) ─────────────────────────────────────

# AES 加密密钥 — 用于加密用户存库的 API Key
# 不设置则自动从 JWT_SECRET_KEY 派生；独立设置可支持密钥轮换
# ENCRYPTION_KEY=

# 数据库连接 — 默认 SQLite 本地文件
# 生产: postgresql+asyncpg://postgres:password@localhost:5432/truthseeker
# DATABASE_URL=sqlite+aiosqlite:///./truthseeker.db

# Redis 连接 — 用于 Session 存储与限流
REDIS_URL=redis://localhost:6379/0

# Logto 配置 (后端 OIDC 交换与 Resource Server 校验)
LOGTO_ENDPOINT=https://your-logto-endpoint.logto.app/
LOGTO_CLIENT_ID=your-client-id
LOGTO_CLIENT_SECRET=your-client-secret
LOGTO_API_RESOURCE=https://api.truthseeker.com

# LangGraph Store 命名空间前缀 (默认 truthseeker)
# STORE_NS_PREFIX=truthseeker

# 注：API Key (DASHSCOPE, DEEPSEEK, TAVILY, BOCHA, ZHIHU, JINA 等)
# 不再通过环境变量配置，请通过前端 Settings → API 密钥 页面写入数据库。
