# ╔════════════════════════════════════════════════════════════════════════╗
# ║  TruthSeeker 环境变量模板 (Docker 适配版)                             ║
# ║  适配 docker-compose.yml 中的服务名 (postgres/redis)                  ║
# ║  复制为 .env 后填入实际值：cp .env.docker.example .env               ║
# ╚════════════════════════════════════════════════════════════════════════╝


# ── 1️⃣ 必填 (缺失会阻止启动) ──────────────────────────────────────────────

# JWT 签名密钥 — 用于签发/验证登录 Token & 派生 AES 加密密钥
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# PostgreSQL 密码 — 必须与 docker-compose.yml 中 POSTGRES_PASSWORD 一致
POSTGRES_PASSWORD=

# Logto OIDC 配置 (后端 Token 校验 & 前端登录)
LOGTO_ENDPOINT=https://your-logto-endpoint.logto.app/
LOGTO_CLIENT_ID=your-client-id
LOGTO_CLIENT_SECRET=your-client-secret
LOGTO_API_RESOURCE=https://api.truthseeker.com


# ── 2️⃣ 可选 (有合理默认值，不设置也能跑) ──────────────────────────────────

# 数据库连接 — Docker 环境下使用 postgres 服务名
# 密码必须与上方 POSTGRES_PASSWORD 保持一致
# 例: postgresql+asyncpg://postgres:your-password@postgres:5432/truthseeker
# DATABASE_URL=postgresql+asyncpg://postgres:your-password@postgres:5432/truthseeker

# Redis 连接 — Docker 环境下使用 redis 服务名
REDIS_URL=redis://redis:6379/0

# 前端 URL (CORS 验证 & Logto 回调)
FRONTEND_URL=http://localhost:3000

# CORS 允许的跨域来源 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AES 加密密钥 — 用于加密用户存库的 API Key
# 不设置则自动从 JWT_SECRET_KEY 派生；独立设置可支持密钥轮换
# ENCRYPTION_KEY=

# LangGraph Store 命名空间前缀
# STORE_NS_PREFIX=truthseeker


# ── 3️⃣ 参考资料：数据库内配置的 API Key ──────────────────────────────────

# 以下密钥不再作为环境变量读取。
# 请启动后登录前端 → 设置 → API 密钥 页面写入数据库 (AES-256 加密存储)。
#
# LLM 提供商:
#   DeepSeek:       sk-xxx                    (deepseek)
#   通义千问:       sk-xxx                    (dashscope)
#
# 搜索引擎:
#   博查 (Bocha):   sk-xxx                    (bocha)
#   Tavily:         tvly-xxx                  (tavily)
#   知乎:           xxx                       (zhihu)
